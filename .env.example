# ─── Banco de Dados ──────────────────────────────────────────────────────────
DB_NAME=bancoNode
DB_USER=root
DB_PASS=
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DIALECT=postgres

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=
JWT_EXPIRES=8h

# ─── Servidor ─────────────────────────────────────────────────────────────────
PORT=3000
APP_URL=https://seudominio.com
ALLOWED_ORIGINS=http://localhost:5173

# ─── WhatsApp ─────────────────────────────────────────────────────────────────
OWNER_PHONE_NUMBER=5511999999999@c.us
WHATSAPP_ID=

# ─── E-mail ───────────────────────────────────────────────────────────────────
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=
MAIL_PASS=

# ─── Stripe ───────────────────────────────────────────────────────────────────
# Obtenha em https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
# Obtenha em https://dashboard.stripe.com/webhooks após registrar o endpoint
# URL do webhook: https://seudominio.com/api/webhooks/stripe
# Eventos obrigatórios: checkout.session.completed, invoice.payment_succeeded,
#   invoice.payment_failed, customer.subscription.deleted, customer.subscription.updated
STRIPE_WEBHOOK_SECRET=whsec_...
# Crie o produto/preço recorrente em https://dashboard.stripe.com/products
# Tipo: Recorrente | Intervalo: Mensal | Moeda: BRL | Valor: R$ 19,90
STRIPE_PRO_PRICE_ID=price_...

# ─── Anthropic (IA para linguagem natural no WhatsApp) ───────────────────────
# Obtenha em https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ─── Slack ────────────────────────────────────────────────────────────────────
# Obtenha em https://api.slack.com/apps → Incoming Webhooks
SLACK_WEBHOOK_ERRORS=
SLACK_WEBHOOK_SUBSCRIPTIONS=
